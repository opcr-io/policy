#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

BIN_PATH=${PWD}/dist/policy_$(go env GOOS)_$(go env GOARCH)

if [[ -n "$(go env GOARM64)" ]]; then
  BIN_PATH+="_$(go env GOARM64)"
fi

if [[ -n "$(go env GOAMD64)" ]]; then
  BIN_PATH+="_$(go env GOAMD64)"
fi

BIN_PATH+="/policy"

export POLICY_TEST=/tmp/policy
export POLICY_CONFIG=/tmp/policy/config.json
export POLICY_FILE_STORE_ROOT=/tmp/policy
export TRACE=1
export CLI_BINARY_PATH=$BIN_PATH